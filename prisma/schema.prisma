generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model aboutsection {
  id        Int      @id @default(autoincrement())
  heading   String   @db.VarChar(255)
  content   String   @db.Text
  imageUrl  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @default(now()) @db.Timestamp(0)
}

model admin_users {
  id        Int       @id @default(autoincrement())
  username  String    @unique(map: "username") @db.VarChar(100)
  password  String    @db.VarChar(255)
  role      String?   @default("admin") @db.VarChar(50)
  createdAt DateTime? @default(now()) @db.DateTime(0)
}

model adminuser {
  id         Int       @id @default(autoincrement())
  email      String    @unique(map: "AdminUser_email_key")
  password   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  name       String    @default("Admin")
  otp        String?   @db.VarChar(10)
  otp_expiry DateTime? @db.DateTime(0)
}

model blog_posts {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(255)
  slug            String    @unique(map: "slug") @db.VarChar(255)
  content         String    @db.Text
  metaTitle       String?   @db.VarChar(255)
  metaDescription String?   @db.Text
  altText         String?   @db.VarChar(255)
  published       Boolean?  @default(true)
  createdAt       DateTime? @default(now()) @db.DateTime(0)
  updatedAt       DateTime? @default(now()) @db.DateTime(0)
}

model blogpost {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique(map: "BlogPost_slug_key")
  content         String   @db.Text
  imageUrl        String?
  imageAlt        String?
  metaTitle       String?
  metaDescription String?  @db.Text
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  altText         String?  @db.VarChar(255)
}

model contentblock {
  id        Int      @id @default(autoincrement())
  key       String   @unique(map: "ContentBlock_key_key")
  value     String   @db.Text
  page      String
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model faq {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String   @db.Text
  order     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model faqs {
  id       Int    @id @default(autoincrement())
  question String @db.VarChar(255)
  answer   String @db.Text
  order    Int?   @default(0)
}

model homefeature {
  id           Int      @id @default(autoincrement())
  sectionId    Int
  icon         String?  @default("✨") @db.VarChar(50)
  title        String   @db.VarChar(255)
  description  String   @db.Text
  displayOrder Int?     @default(0)
  isActive     Boolean? @default(true)
  createdAt    DateTime @default(now()) @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @db.Timestamp(0)
}

model homesection {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  subtitle     String?  @db.VarChar(255)
  content      String?  @db.Text
  imageUrl     String?  @db.VarChar(255)
  sectionType  String?  @default("custom") @db.VarChar(50)
  displayOrder Int?     @default(0)
  isActive     Boolean? @default(true)
  createdAt    DateTime @default(now()) @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @db.Timestamp(0)
}

model order {
  id            Int         @id @default(autoincrement())
  customerName  String
  customerPhone String
  customerEmail String?
  address       String      @db.Text
  city          String
  totalAmount   Float
  paymentMethod String
  status        String      @default("Processing")
  items         String?     @db.LongText
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  paymentStatus String      @default("PENDING")
  transactionId String?
  userId        Int?
  user          user?       @relation(fields: [userId], references: [id], map: "Order_userId_fkey")
  orderitem     orderitem[]

  @@index([userId], map: "Order_userId_fkey")
}

model orderitem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     order   @relation(fields: [orderId], references: [id], map: "OrderItem_orderId_fkey")
  product   product @relation(fields: [productId], references: [id], map: "OrderItem_productId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@index([productId], map: "OrderItem_productId_fkey")
}

model orders {
  id            Int       @id @default(autoincrement())
  customerName  String    @db.VarChar(255)
  customerPhone String    @db.VarChar(20)
  customerEmail String?   @db.VarChar(255)
  address       String    @db.Text
  city          String    @db.VarChar(100)
  totalAmount   Decimal   @db.Decimal(10, 2)
  paymentMethod String    @db.VarChar(50)
  status        String?   @default("Processing") @db.VarChar(50)
  items         String    @db.LongText
  userId        Int?
  createdAt     DateTime? @default(now()) @db.DateTime(0)
  updatedAt     DateTime? @default(now()) @db.DateTime(0)
}

model payment_gateways {
  id          Int                    @id @default(autoincrement())
  gatewayName String                 @db.VarChar(50)
  isEnabled   Boolean?               @default(false)
  apiKey      String?                @db.VarChar(255)
  apiSecret   String?                @db.VarChar(255)
  mode        payment_gateways_mode? @default(test)
}

model paymentgateway {
  id         Int      @id @default(autoincrement())
  name       String   @unique(map: "PaymentGateway_name_key")
  enabled    Boolean  @default(false)
  mode       String   @default("test")
  testApiKey String?
  testSecret String?
  liveApiKey String?
  liveSecret String?
  updatedAt  DateTime
}

model paymentgatewayconfig {
  id          Int                        @id @default(autoincrement())
  gatewayName String                     @db.VarChar(50)
  isEnabled   Boolean?                   @default(false)
  apiKey      String?                    @db.VarChar(255)
  apiSecret   String?                    @db.VarChar(255)
  mode        paymentgatewayconfig_mode? @default(test)
}

model product {
  id             Int         @id @default(autoincrement())
  name           String
  description    String      @db.Text
  price          Float
  volume         String
  imageUrl       String?
  stock          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime
  healthBenefits String?     @db.Text
  howToUse       String?     @db.Text
  images         String?     @db.LongText
  orderitem      orderitem[]
}

model products {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  description     String    @db.Text
  price           Decimal   @db.Decimal(10, 2)
  volume          String    @db.VarChar(50)
  stock           Int?      @default(0)
  images          String?   @db.LongText
  health_benefits String?   @db.Text
  how_to_use      String?   @db.Text
  createdAt       DateTime? @default(now()) @db.DateTime(0)
  updatedAt       DateTime? @default(now()) @db.DateTime(0)
}

model settings {
  id             Int     @id @default(autoincrement())
  contactEmail   String
  whatsappNumber String
  supportEmail   String?
  location       String?
}

model site_settings {
  id             Int     @id @default(autoincrement())
  siteName       String? @default("Auxiron Ghee") @db.VarChar(255)
  siteTagline    String? @default("Identity of Purity") @db.VarChar(255)
  logoUrl        String? @db.VarChar(255)
  heroHeading    String? @default("Shuddh Desi Bilona Ghee") @db.VarChar(255)
  heroSubheading String? @default("Pure by Tradition. Trusted for Generations.") @db.Text
  heroBgUrl      String? @db.VarChar(255)
  contactEmail   String? @db.VarChar(255)
  contactPhone   String? @db.VarChar(20)
  whatsappNumber String? @db.VarChar(20)
  officeAddress  String? @db.Text
  returnPolicy   String? @db.Text
  shippingPolicy String? @db.Text
  privacyPolicy  String? @db.Text
}

model sitesettings {
  id             Int     @id @default(autoincrement())
  siteName       String? @default("Auxiron Ghee") @db.VarChar(255)
  siteTagline    String? @default("Identity of Purity") @db.VarChar(255)
  logoUrl        String? @db.VarChar(255)
  heroHeading    String? @default("Shuddh Desi Bilona Ghee") @db.VarChar(255)
  heroSubheading String? @default("Pure by Tradition. Trusted for Generations.") @db.Text
  heroBgUrl      String? @db.VarChar(255)
  contactEmail   String? @db.VarChar(255)
  contactPhone   String? @db.VarChar(20)
  whatsappNumber String? @db.VarChar(20)
  officeAddress  String? @db.Text
  returnPolicy   String? @db.Text
  shippingPolicy String? @db.Text
  privacyPolicy  String? @db.Text
}

model smtpsettings {
  id             Int      @id @default(autoincrement())
  smtpHost       String   @db.VarChar(255)
  smtpPort       String   @db.VarChar(10)
  smtpUsername   String   @db.VarChar(255)
  smtpPassword   String   @db.VarChar(255)
  smtpEncryption String   @db.VarChar(10)
  senderEmail    String   @db.VarChar(255)
  senderName     String   @db.VarChar(255)
  updatedAt      DateTime @default(now()) @db.Timestamp(0)
  otpSubject     String?  @default("Your OTP Code - Auxiron") @db.VarChar(255)
  otpTemplate    String?  @db.Text
}

model testimonial {
  id           Int      @id @default(autoincrement())
  sectionId    Int?
  name         String   @db.VarChar(255)
  location     String?  @db.VarChar(255)
  review       String   @db.Text
  rating       Int?     @default(5)
  displayOrder Int?     @default(0)
  isActive     Boolean? @default(true)
  createdAt    DateTime @default(now()) @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @db.Timestamp(0)
}

model testimonials {
  id           Int       @id @default(autoincrement())
  customerName String    @db.VarChar(255)
  rating       Int?      @default(5)
  content      String    @db.Text
  createdAt    DateTime? @default(now()) @db.DateTime(0)
}

model user {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique(map: "User_email_key")
  password   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  otp        String?   @db.VarChar(10)
  otp_expiry DateTime? @db.DateTime(0)
  isVerified Boolean   @default(false)
  location   String?   @db.VarChar(255)
  order      order[]
}

model users {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  email     String    @unique(map: "email") @db.VarChar(255)
  password  String    @db.VarChar(255)
  phone     String?   @db.VarChar(20)
  address   String?   @db.Text
  createdAt DateTime? @default(now()) @db.DateTime(0)
  updatedAt DateTime? @default(now()) @db.DateTime(0)
}

enum paymentgatewayconfig_mode {
  test
  live
}

enum payment_gateways_mode {
  test
  live
}
